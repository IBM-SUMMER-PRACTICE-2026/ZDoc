 PROC_1198: PROC(VALUE_A, VALUE_B) RETURNS(FIXED(31));
   DCL VALUE_A FIXED(31);                /* Parameter VALUE_A          @L0A*/
   DCL VALUE_B FIXED(31);                /* Parameter VALUE_B          @L0A*/
   DCL LOCAL_1198 FIXED(31);       /* Local scratch variable    @L0A*/
   LOCAL_1198 = 1198;          /* Assign scratch value      @L0A*/
   DO I = 1 TO 3;                      /* Small padding loop        @L0A*/
      LOCAL_1198 = LOCAL_1198 + I;  /* Accumulate            @L0A*/
   END;                                /* End. Small padding loop   @L0A*/
   RETURN 0;                           /* Success                  @L0A*/
 END PROC_1198; /* End PROC_1198                                    @L0A*/
