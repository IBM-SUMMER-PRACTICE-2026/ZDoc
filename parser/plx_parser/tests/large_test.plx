 @PROCESS;
 @PROCESS OVERRIDE FORMAT NOIMP(0FX);
 /********************************************************************/
 /*  START OF SPECIFICATIONS                                           @L0A*/
 /*  MODULE-NAME = LARGE_TEST_MODULE                                   @L0A*/
 /*  FUNCTION = Synthetic large PL/X module for parser perf testing    @L0A*/
 /********************************************************************/
 LARGE_TEST_MODULE: PROC OPTIONS(MAIN);

 DCL RC FIXED(31);                 /* Return code                @L0A*/
 DCL I FIXED(31);                  /* Loop variable              @L0A*/
 @EJECT;
 /********************************************************************/
 /*                                                                    @L0A*/
 /*  Title: PROC_0000:                                                 @L0A*/
 /*                                                                    @L0A*/
 /*  Logic: Demonstrates procedure number 0 for large-scale            @L0A*/
 /*         parser performance testing of the ZDoc PL/X parser         @L0A*/
 /*                                                                    @L0A*/
 /*  Input: None                                                       @L0A*/
 /*                                                                    @L0A*/
 /*  Output: Return code - Fixed(31), 0 = success, 8 = failure         @L0A*/
 /*                                                                    @L0A*/
 /********************************************************************/
 PROC_0000: PROC RETURNS(FIXED(31));
   DCL LOCAL_0 FIXED(31);       /* Local scratch variable    @L0A*/
   LOCAL_0 = 0;          /* Assign scratch value      @L0A*/
   DO I = 1 TO 3;                      /* Small padding loop        @L0A*/
      LOCAL_0 = LOCAL_0 + I;  /* Accumulate            @L0A*/
   END;                                /* End. Small padding loop   @L0A*/
   RETURN 0;                           /* Success                  @L0A*/
 END PROC_0000; /* End PROC_0000                                    @L0A*/
 @EJECT;
